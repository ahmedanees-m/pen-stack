# PEN-STACK Web Platform — environment (copy to .env; all optional).
#
# The science never depends on the LLM: with neither backend reachable, the co-scientist uses the deterministic
# narrator. These only configure the OPTIONAL narration layer + where the frontend finds the API.

# --- LLM narration (optional) -------------------------------------------------------------------------
# Backend order. "ollama,nemotron" = local/private first (default). "nemotron,ollama" = speed first: the hosted
# 49B answers in ~5s vs ~17-50s on a workstation GPU (RTX A4000). The grounding guard runs whichever answers.
# PEN_STACK_LLM_ORDER=ollama,nemotron

# Local Ollama (free, private). Default model qwen2.5:3b-instruct (~2x faster than 7B; llama3.2:3b is fastest).
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b-instruct
# OLLAMA_KEEP_ALIVE=30m       # keep the model resident on the GPU so calls don't pay the cold-start each time

# NVIDIA-hosted Nemotron (free tier, fast). Leave unset to skip; or put the key in configs/nvidia_api_key.txt.
# NVIDIA_API_KEY=nvapi-...
# NEMOTRON_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1

# Force the deterministic narrator (no LLM call at all): set to 1.
# PEN_STACK_NO_LLM=0
# PEN_STACK_LLM_TIMEOUT=150    # per-backend budget (s); a 7B local model can take 60-90s, the 49B cloud ~5s
# OLLAMA_NUM_PREDICT=400

# --- frontend (Vite build/dev) ------------------------------------------------------------------------
# Where the frontend reaches the gateway. Empty = same origin (the gateway serves the built dist/). For a
# separate dev server, the Vite proxy already forwards /api + /chat to http://localhost:8000.
# VITE_API_BASE=
